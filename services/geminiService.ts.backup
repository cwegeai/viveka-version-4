
import { GoogleGenAI, Type } from "@google/genai";
import { TranscriptionResult, SpeakerTurn } from "../types.ts";

const sleep = (ms: number) => new Promise(resolve => setTimeout(resolve, ms));
const CHUNK_SIZE_MB = 4; // Smaller chunks for higher reliability in varying network conditions

const getAudioDuration = async (file: File): Promise<number> => {
    return new Promise((resolve) => {
        const audio = document.createElement('audio');
        const objectUrl = URL.createObjectURL(file);
        audio.src = objectUrl;
        audio.onloadedmetadata = () => {
            const duration = audio.duration;
            URL.revokeObjectURL(objectUrl);
            resolve(duration);
        };
        audio.onerror = () => resolve(0);
    });
};

const blobToBase64 = (blob: Blob): Promise<string> => {
    return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
            if (typeof reader.result === 'string') {
                resolve(reader.result.split(',')[1]);
            } else {
                reject(new Error("Failed to read chunk"));
            }
        };
        reader.onerror = reject;
        reader.readAsDataURL(blob);
    });
};

const processChunk = async (
    ai: GoogleGenAI, 
    chunkBase64: string, 
    mimeType: string,
    timeOffset: number,
    chunkIndex: number,
    totalChunks: number
): Promise<SpeakerTurn[]> => {
    const response = await ai.models.generateContent({
        model: "gemini-3-flash-preview",
        contents: [{
            parts: [
                { inlineData: { mimeType, data: chunkBase64 } },
                {
                    text: `TASK: Diarize and transcribe this audio segment. 
                    - Segment context: PART ${chunkIndex + 1} of ${totalChunks}.
                    - Speaker Labels: Use 'Speaker 1', 'Speaker 2', etc.
                    - Transcription: Provide verbatim 'original' text in the source language and an accurate 'translated' text in English.
                    - Timing: Timestamps must be relative to the start of this chunk (0.0).
                    - Format: Return strictly JSON.`
                },
            ],
        }],
        config: {
            responseMimeType: "application/json",
            responseSchema: {
                type: Type.OBJECT,
                properties: {
                    turns: {
                        type: Type.ARRAY,
                        items: {
                            type: Type.OBJECT,
                            properties: {
                                speaker: { type: Type.STRING },
                                original: { type: Type.STRING },
                                translated: { type: Type.STRING },
                                startTime: { type: Type.NUMBER },
                                endTime: { type: Type.NUMBER }
                            },
                            required: ["speaker", "original", "translated", "startTime", "endTime"]
                        }
                    }
                },
                required: ["turns"]
            }
        },
    });

    try {
        const result = JSON.parse(response.text || '{"turns": []}');
        return result.turns.map((t: SpeakerTurn) => ({
            ...t,
            startTime: Math.max(0, t.startTime + timeOffset),
            endTime: t.endTime + timeOffset
        }));
    } catch (e) {
        console.error("Failed to parse chunk JSON:", response.text);
        return [];
    }
};

const generateFinalAnalysis = async (
    ai: GoogleGenAI, 
    transcriptContext: string
): Promise<Partial<TranscriptionResult>> => {
    const response = await ai.models.generateContent({
        model: "gemini-3-flash-preview",
        contents: [{
            parts: [
                {
                    text: `Analyze this field report transcript. Extract executive intelligence.
                    
TRANSCRIPT:
${transcriptContext.substring(0, 800000)}

REQUIRED JSON OUTPUT:
1. 'summary': A high-level qualitative summary of the session.
2. 'keyPoints': 5 actionable field findings.
3. 'thematicAnalysis': 4-6 categories with 'insight' and a 'relevanceScore' (0-100).
4. 'language': Detected languages (e.g. "English", "Spanish").
5. 'speakerCount': Total unique participants.`
                }
            ]
        }],
        config: {
            responseMimeType: "application/json",
            responseSchema: {
                type: Type.OBJECT,
                properties: {
                    language: { type: Type.STRING },
                    speakerCount: { type: Type.NUMBER },
                    summary: { type: Type.STRING },
                    keyPoints: { type: Type.ARRAY, items: { type: Type.STRING } },
                    thematicAnalysis: {
                        type: Type.ARRAY,
                        items: {
                            type: Type.OBJECT,
                            properties: {
                                category: { type: Type.STRING },
                                insight: { type: Type.STRING },
                                relevanceScore: { type: Type.NUMBER }
                            },
                            required: ["category", "insight", "relevanceScore"]
                        }
                    }
                },
                required: ["language", "speakerCount", "summary", "keyPoints", "thematicAnalysis"]
            }
        }
    });

    try {
        return JSON.parse(response.text || '{}');
    } catch (e) {
        return {
            summary: "Analysis generation failed due to content complexity.",
            keyPoints: ["Manual review required"],
            thematicAnalysis: [],
            language: "Unknown",
            speakerCount: 0
        };
    }
};

export const transcribeAudio = async (
    file: File,
    mimeType: string,
    onStatusChange: (status: string) => void
): Promise<TranscriptionResult> => {
    // Fixed: Initializing GoogleGenAI with process.env.API_KEY directly as per strictly enforced guidelines
    const ai = new GoogleGenAI({ apiKey: process.env.API_KEY });

    const chunkSize = CHUNK_SIZE_MB * 1024 * 1024;
    const totalChunks = Math.ceil(file.size / chunkSize);
    
    let allTurns: SpeakerTurn[] = [];
    let currentTimeOffset = 0;

    for (let i = 0; i < totalChunks; i++) {
        const start = i * chunkSize;
        const end = Math.min(start + chunkSize, file.size);
        const chunkBlob = file.slice(start, end, mimeType);
        
        onStatusChange(`Syncing Segment ${i + 1}/${totalChunks}...`);

        const chunkDuration = await getAudioDuration(new File([chunkBlob], "temp", { type: mimeType }));
        const chunkBase64 = await blobToBase64(chunkBlob);

        let retries = 2;
        while (retries >= 0) {
            try {
                const chunkTurns = await processChunk(ai, chunkBase64, mimeType, currentTimeOffset, i, totalChunks);
                allTurns = [...allTurns, ...chunkTurns];
                currentTimeOffset += chunkDuration;
                break;
            } catch (e: any) {
                if (retries === 0) throw e;
                retries--;
                await sleep(3000);
            }
        }
    }

    onStatusChange("Finalizing Qualitative Matrix...");
    
    const context = allTurns.map(t => `${t.speaker}: ${t.translated}`).join('\n\n');
    const analysis = await generateFinalAnalysis(ai, context);

    return {
        turns: allTurns,
        text: allTurns.map(t => `${t.speaker}: ${t.original}`).join('\n'),
        translatedText: allTurns.map(t => `${t.speaker}: ${t.translated}`).join('\n'),
        ...analysis
    };
};
