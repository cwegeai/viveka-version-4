DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_BASE_URL=https://api.deepgram.com
DEEPGRAM_LISTEN_PATH=/v1/listen
STT_REQUEST_TIMEOUT_SECONDS=600

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379/0

VIVEKA_BACKEND_HOST=127.0.0.1
VIVEKA_BACKEND_PORT=8000
VIVEKA_BACKEND_CORS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
VIVEKA_TEMP_ROOT=.backend_runtime
VIVEKA_BACKGROUND_JOBS_ENABLED=true
VIVEKA_BACKGROUND_JOB_MIN_BYTES=0
VIVEKA_BACKGROUND_JOB_MAX_BYTES=31457280
VIVEKA_BACKGROUND_JOB_START_TIMEOUT_SECONDS=15
VIVEKA_PROGRESS_RETENTION_SECONDS=86400
VIVEKA_PROGRESS_POLL_INTERVAL_SECONDS=0.25
VIVEKA_SMALL_WORKER_COUNT=4
VIVEKA_MEDIUM_WORKER_COUNT=4
VIVEKA_LARGE_WORKER_COUNT=4
VIVEKA_REDIS_MAX_CONNECTIONS=6
VIVEKA_AUTH_SESSION_HOURS=24
VIVEKA_PASSWORD_RESET_TOKEN_MINUTES=30
VIVEKA_AUTH_EXPOSE_RESET_TOKEN=true
VIVEKA_ADMIN_EMAILS=
VIVEKA_DIRECT_TRANSCRIBE_MAX_SECONDS=1200
VIVEKA_GEMINI_AUTO_MAX_SECONDS=900
VIVEKA_CHUNK_MINUTES=10
VIVEKA_OVERLAP_SECONDS=15

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=
SMTP_SENDER_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=180