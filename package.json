{
  "name": "viveka-ai-researcher",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "backend:install": "python -m pip install -r backend/requirements.txt",
    "backend:dev": "python -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000",
    "backend:worker": "python -m backend.app.redis_worker",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "latest",
    "html2canvas": "^1.4.1",
    "jsonrepair": "^3.13.2",
    "jspdf": "^4.1.0",
    "lucide-react": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
